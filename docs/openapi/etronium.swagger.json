{
  "swagger": "2.0",
  "info": {
    "title": "Etronium-Scdr API",
    "description": "Single-runtime over distributed machines. Scheduler coordinates lords (donors) that execute tenant tasks in OCI containers via containerd. gRPC is the primary protocol; OpenAPI is documentation-only.",
    "version": "v1",
    "contact": {
      "name": "Etronium-Scdr"
    }
  },
  "tags": [
    {
      "name": "SchedulerService"
    },
    {
      "name": "LordService"
    }
  ],
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/api/v1/lords": {
      "get": {
        "summary": "List registered lords",
        "description": "Public list of lords with capacity/reputation/health.",
        "operationId": "SchedulerService_ListLords",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListLordsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "onlyHealthy",
            "description": "default true",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/lords/register": {
      "post": {
        "summary": "Lord registration",
        "description": "Lord registers itself with scheduler on startup.",
        "operationId": "LordService_Register",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RegisterResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RegisterRequest"
            }
          }
        ],
        "tags": [
          "lord"
        ]
      }
    },
    "/api/v1/lords/{lordId}/heartbeat": {
      "post": {
        "summary": "Lord heartbeat (unary in MVP)",
        "description": "Keepalive + current load. Phase 3+ -\u003e bidi stream.",
        "operationId": "LordService_Heartbeat",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1HeartbeatResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "lordId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LordServiceHeartbeatBody"
            }
          }
        ],
        "tags": [
          "lord"
        ]
      }
    },
    "/api/v1/lords/{lordId}/lazy-death": {
      "post": {
        "summary": "Acknowledge lazy death",
        "description": "Lord announces planned shutdown. Scheduler drains it gracefully.",
        "operationId": "LordService_AcknowledgeLazyDeath",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1AcknowledgeLazyDeathResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "lordId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LordServiceAcknowledgeLazyDeathBody"
            }
          }
        ],
        "tags": [
          "lord"
        ]
      }
    },
    "/api/v1/tasks": {
      "get": {
        "summary": "List tenant tasks",
        "description": "Paginated tenant task list, newest first.",
        "operationId": "SchedulerService_ListTasks",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListTasksResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "tenantId",
            "description": "фильтр по тенанту; пустой = все (для admin)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "limit",
            "description": "default 50, max 500",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "opaque cursor для пагинации",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "tenant"
        ]
      },
      "post": {
        "summary": "Submit a new task",
        "description": "Tenant submits a task for execution. Returns task_id.",
        "operationId": "SchedulerService_SubmitTask",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1SubmitTaskResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1SubmitTaskRequest"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/tasks/{taskId}": {
      "get": {
        "summary": "Get task status",
        "description": "Returns current task status. Idempotent.",
        "operationId": "SchedulerService_GetTask",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Task"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/tasks/{taskId}/cancel": {
      "post": {
        "summary": "Cancel a running task",
        "description": "Best-effort cancellation. No guarantee of immediate effect.",
        "operationId": "SchedulerService_CancelTask",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CancelTaskResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulerServiceCancelTaskBody"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/tasks/{taskId}/control": {
      "post": {
        "summary": "Control task lifecycle (pause/resume/restart/relocate/cancel)",
        "description": "Operator-level control over running task. Cascades to fan-out children.",
        "operationId": "SchedulerService_ControlTask",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ControlTaskResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulerServiceControlTaskBody"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    }
  },
  "definitions": {
    "LogChunkStream": {
      "type": "string",
      "enum": [
        "STREAM_UNSPECIFIED",
        "STREAM_STDOUT",
        "STREAM_STDERR"
      ],
      "default": "STREAM_UNSPECIFIED"
    },
    "LordServiceAcknowledgeLazyDeathBody": {
      "type": "object",
      "properties": {
        "gracePeriodSec": {
          "type": "integer",
          "format": "int32",
          "title": "за сколько секунд лорд хочет завершиться"
        }
      }
    },
    "LordServiceHeartbeatBody": {
      "type": "object",
      "properties": {
        "currentCpuPct": {
          "type": "integer",
          "format": "int32",
          "title": "текущая утилизация, 0..100"
        },
        "currentMemMb": {
          "type": "integer",
          "format": "int32",
          "title": "текущее потребление RAM"
        },
        "activeTasks": {
          "type": "integer",
          "format": "int32",
          "title": "сколько задач сейчас выполняется"
        }
      }
    },
    "SchedulerServiceCancelTaskBody": {
      "type": "object",
      "properties": {
        "force": {
          "type": "boolean",
          "title": "true = SIGKILL, false (default) = SIGTERM + grace period"
        }
      }
    },
    "SchedulerServiceControlTaskBody": {
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/definitions/v1ControlAction"
        },
        "force": {
          "type": "boolean",
          "title": "для CANCEL: true=SIGKILL, false=SIGTERM+grace"
        },
        "reason": {
          "type": "string",
          "title": "human-readable, логируется в audit"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1AcknowledgeLazyDeathResponse": {
      "type": "object",
      "properties": {
        "ack": {
          "type": "boolean"
        },
        "drainTimeoutSec": {
          "type": "integer",
          "format": "int32",
          "title": "сколько ждать до принудительного выведения"
        }
      }
    },
    "v1CancelTaskResponse": {
      "type": "object",
      "properties": {
        "acknowledged": {
          "type": "boolean",
          "title": "scheduler принял запрос"
        },
        "currentStatus": {
          "$ref": "#/definitions/v1TaskStatus"
        }
      }
    },
    "v1ContainerStarted": {
      "type": "object",
      "properties": {
        "containerId": {
          "type": "string",
          "title": "containerd container ID"
        },
        "at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1ControlAction": {
      "type": "string",
      "enum": [
        "CONTROL_ACTION_UNSPECIFIED",
        "CONTROL_ACTION_PAUSE",
        "CONTROL_ACTION_RESUME",
        "CONTROL_ACTION_RESTART",
        "CONTROL_ACTION_RELOCATE",
        "CONTROL_ACTION_CANCEL"
      ],
      "default": "CONTROL_ACTION_UNSPECIFIED",
      "description": "Control action для ControlTask.\n\n - CONTROL_ACTION_PAUSE: freeze cgroup, SIGSTOP\n - CONTROL_ACTION_RESUME: thaw cgroup, SIGCONT\n - CONTROL_ACTION_RESTART: kill + rerun (same task_id, fresh container)\n - CONTROL_ACTION_RELOCATE: stop + requeue на другом лорде (placement заново)\n - CONTROL_ACTION_CANCEL: алиас CancelTask для единого API"
    },
    "v1ControlTaskResponse": {
      "type": "object",
      "properties": {
        "acknowledged": {
          "type": "boolean"
        },
        "currentStatus": {
          "$ref": "#/definitions/v1TaskStatus"
        },
        "affectedTaskIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "при fan-out: parent + children"
        }
      }
    },
    "v1HeartbeatResponse": {
      "type": "object",
      "properties": {
        "ack": {
          "type": "boolean"
        },
        "nextHeartbeatSec": {
          "type": "integer",
          "format": "int32",
          "title": "hint от scheduler'а"
        },
        "drain": {
          "type": "boolean",
          "title": "true → лорд должен начать lazy death"
        }
      }
    },
    "v1ListLordsResponse": {
      "type": "object",
      "properties": {
        "lords": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Lord"
          }
        }
      }
    },
    "v1ListTasksResponse": {
      "type": "object",
      "properties": {
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Task"
          }
        },
        "nextPageToken": {
          "type": "string"
        }
      }
    },
    "v1LogChunk": {
      "type": "object",
      "properties": {
        "stream": {
          "$ref": "#/definitions/LogChunkStream"
        },
        "data": {
          "type": "string",
          "format": "byte",
          "title": "raw bytes, UTF-8 assumed"
        },
        "offset": {
          "type": "string",
          "format": "int64",
          "title": "byte offset от начала (для ordering и resume)"
        }
      }
    },
    "v1Lord": {
      "type": "object",
      "properties": {
        "lordId": {
          "type": "string",
          "title": "уникальный ID, стабильный между рестартами"
        },
        "hostname": {
          "type": "string",
          "title": "os.Hostname() — для отладки и \"wow\" момента"
        },
        "capacity": {
          "$ref": "#/definitions/v1ResourceSpec",
          "title": "задекларированные возможности"
        },
        "healthy": {
          "type": "boolean",
          "title": "последний heartbeat был свежим"
        },
        "reputation": {
          "type": "number",
          "format": "double",
          "title": "0.0..1.0, computed scheduler'ом"
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "Информация о лорде (публичная часть, без секретов)."
    },
    "v1PullStarted": {
      "type": "object",
      "properties": {
        "image": {
          "type": "string"
        },
        "at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1RegisterRequest": {
      "type": "object",
      "properties": {
        "hostname": {
          "type": "string"
        },
        "os": {
          "type": "string",
          "title": "\"linux\""
        },
        "arch": {
          "type": "string",
          "title": "\"amd64\""
        },
        "cpuTotal": {
          "type": "integer",
          "format": "int32",
          "title": "cores"
        },
        "memTotalMb": {
          "type": "integer",
          "format": "int32"
        },
        "defaultCapacity": {
          "$ref": "#/definitions/v1ResourceSpec",
          "title": "что лорд готов выделять по умолчанию"
        },
        "authToken": {
          "type": "string",
          "title": "pre-shared, пока в plaintext в metadata (Phase 0)"
        }
      }
    },
    "v1RegisterResponse": {
      "type": "object",
      "properties": {
        "lordId": {
          "type": "string",
          "title": "присвоенный scheduler'ом ID (ULID)"
        },
        "heartbeatIntervalSec": {
          "type": "integer",
          "format": "int32",
          "title": "рекомендуемый интервал (default 10)"
        }
      }
    },
    "v1ResourceSpec": {
      "type": "object",
      "properties": {
        "cpuQuotaPct": {
          "type": "integer",
          "format": "int32",
          "title": "1..100, default 50"
        },
        "memLimitMb": {
          "type": "integer",
          "format": "int32",
          "title": "\u003e 0, default 256"
        },
        "timeoutSec": {
          "type": "integer",
          "format": "int32",
          "title": "\u003e 0, default 30, max 600"
        }
      },
      "title": "Запрашиваемые ресурсы для контейнера. Маппится в cgroups v2:\n  cpu.max        = quota + period (period обычно 100000)\n  memory.max     = mem_limit_mb * 1024 * 1024"
    },
    "v1SubmitTaskRequest": {
      "type": "object",
      "properties": {
        "tenantId": {
          "type": "string",
          "title": "пока pre-shared per CLI install; auth — Phase 2+"
        },
        "image": {
          "type": "string",
          "title": "OCI reference, e.g. \"alpine\", \"alpine:3.20\", \"ghcr.io/midaswr/myimage:tag\""
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "argv-style: [\"sh\", \"-c\", \"echo hi\"]"
        },
        "resources": {
          "$ref": "#/definitions/v1ResourceSpec",
          "title": "optional, defaults из конфига scheduler'а"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "env vars для контейнера (Phase 1+)"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "произвольные метаданные тенанта"
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1VolumeMount"
          },
          "title": "см. VolumeMount; статика/DFS/tmpfs"
        },
        "targetLordCount": {
          "type": "integer",
          "format": "int32",
          "title": "fan-out: 1 = один лорд, N = параллельно N лордов (ответ на OpenQ #1)"
        }
      }
    },
    "v1SubmitTaskResponse": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string",
          "title": "ULID, sortable; parent task_id если target_lord_count \u003e 1"
        },
        "initialStatus": {
          "$ref": "#/definitions/v1TaskStatus",
          "title": "обычно QUEUED"
        },
        "childTaskIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "populated если был fan-out (parent → N children)"
        }
      }
    },
    "v1Task": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "tenantId": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resources": {
          "$ref": "#/definitions/v1ResourceSpec"
        },
        "status": {
          "$ref": "#/definitions/v1TaskStatus"
        },
        "landlordId": {
          "type": "string",
          "title": "ID лорда, который исполняет (set после placement)"
        },
        "result": {
          "$ref": "#/definitions/v1TaskResult",
          "title": "populated когда status in (COMPLETED, FAILED, CANCELED)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "v1TaskEvent": {
      "type": "object",
      "properties": {
        "statusChanged": {
          "$ref": "#/definitions/v1TaskStatus",
          "title": "новый статус"
        },
        "logChunk": {
          "$ref": "#/definitions/v1LogChunk",
          "title": "stdout/stderr"
        },
        "finalResult": {
          "$ref": "#/definitions/v1TaskResult",
          "title": "отправляется один раз перед закрытием стрима"
        },
        "at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "TaskEvent — то что шлётся в StreamTask (для тенанта).\n\nОбъединяет status changes + log chunks + result в один поток."
    },
    "v1TaskResult": {
      "type": "object",
      "properties": {
        "exitCode": {
          "type": "integer",
          "format": "int32"
        },
        "stdout": {
          "type": "string",
          "title": "полный stdout (или truncated — см. flags)"
        },
        "stderr": {
          "type": "string"
        },
        "durationMs": {
          "type": "string",
          "format": "int64"
        },
        "cpuUsageUsec": {
          "type": "string",
          "format": "int64",
          "title": "из cpu.stat cgroup"
        },
        "memPeakBytes": {
          "type": "string",
          "format": "int64",
          "title": "пиковое потребление памяти"
        },
        "error": {
          "type": "string",
          "title": "human-readable если FAILED"
        }
      },
      "description": "Финальный результат задачи."
    },
    "v1TaskStatus": {
      "type": "string",
      "enum": [
        "TASK_STATUS_UNSPECIFIED",
        "TASK_STATUS_QUEUED",
        "TASK_STATUS_SCHEDULED",
        "TASK_STATUS_PULLING",
        "TASK_STATUS_RUNNING",
        "TASK_STATUS_COMPLETED",
        "TASK_STATUS_FAILED",
        "TASK_STATUS_CANCELED"
      ],
      "default": "TASK_STATUS_UNSPECIFIED",
      "description": "- TASK_STATUS_UNSPECIFIED: sentinel — никогда не должен появляться в API\n - TASK_STATUS_QUEUED: принята scheduler'ом, ждёт placement\n - TASK_STATUS_SCHEDULED: placement выбрал лорда, задача отправляется\n - TASK_STATUS_PULLING: lord забрал задачу (в случае pull-модели)\n - TASK_STATUS_RUNNING: контейнер стартовал\n - TASK_STATUS_COMPLETED: exit code = 0\n - TASK_STATUS_FAILED: exit code != 0 или runtime error\n - TASK_STATUS_CANCELED: tenant/lord отменил до завершения",
      "title": "Task lifecycle states.\nFSM: QUEUED → SCHEDULED → PULLING → RUNNING → (COMPLETED | FAILED | CANCELED)"
    },
    "v1TaskUpdate": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/v1TaskStatus",
          "title": "новый статус"
        },
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "logChunk": {
          "$ref": "#/definitions/v1LogChunk",
          "title": "chunk stdout/stderr во время RUNNING"
        },
        "result": {
          "$ref": "#/definitions/v1TaskResult",
          "title": "финальный, при COMPLETED/FAILED/CANCELED"
        },
        "pullStarted": {
          "$ref": "#/definitions/v1PullStarted",
          "title": "лорд начал pull образа"
        },
        "containerStarted": {
          "$ref": "#/definitions/v1ContainerStarted",
          "title": "containerd создал контейнер"
        }
      },
      "description": "TaskUpdate — то что лорд шлёт scheduler'у в RunTask stream.\n\nЭволюция статусов внутри одной задачи:\n  QUEUED → SCHEDULED → PULLING → RUNNING → COMPLETED|FAILED|CANCELED"
    },
    "v1VolumeMount": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "имя внутри контейнера, должно быть валидным как том containerd"
        },
        "type": {
          "$ref": "#/definitions/v1VolumeType"
        },
        "source": {
          "type": "string",
          "title": "см. формат выше; для TMPFS — size, напр. \"100mb\""
        },
        "mountPath": {
          "type": "string",
          "title": "абсолютный путь в контейнере"
        },
        "readOnly": {
          "type": "boolean"
        },
        "dfsKeyId": {
          "type": "string",
          "title": "опционально, какой pre-shared ключ использовать (DFS only)"
        }
      }
    },
    "v1VolumeType": {
      "type": "string",
      "enum": [
        "VOLUME_TYPE_UNSPECIFIED",
        "VOLUME_TYPE_STATIC",
        "VOLUME_TYPE_DFS",
        "VOLUME_TYPE_TMPFS"
      ],
      "default": "VOLUME_TYPE_UNSPECIFIED",
      "title": "- VOLUME_TYPE_STATIC: чтение со scheduler'а (read-only по умолчанию)\n - VOLUME_TYPE_DFS: чтение/запись из защищённой DFS (auth на lord'е)\n - VOLUME_TYPE_TMPFS: RAM-backed, ephemeral"
    }
  }
}
