{
  "swagger": "2.0",
  "info": {
    "title": "Etronium-Scdr API",
    "description": "MOSIX-class Single System Image over Linux user-space. Scheduler as NUMA scheduler, lords as cores, processes as threads.",
    "version": "v2",
    "contact": {
      "name": "Etronium-Scdr"
    }
  },
  "tags": [
    {
      "name": "SchedulerService"
    },
    {
      "name": "LordService"
    }
  ],
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/api/v1/lords": {
      "get": {
        "summary": "List lords (NUMA cores view)",
        "description": "Полный дамп для admin/monitoring.",
        "operationId": "SchedulerService_ListLords",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListLordsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "onlyHealthy",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "admin"
        ]
      }
    },
    "/api/v1/lords/register": {
      "post": {
        "summary": "Lord registration",
        "operationId": "LordService_Register",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RegisterResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RegisterRequest"
            }
          }
        ],
        "tags": [
          "lord"
        ]
      }
    },
    "/api/v1/lords/{lordId}/heartbeat": {
      "post": {
        "summary": "Lord heartbeat",
        "operationId": "LordService_Heartbeat",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1HeartbeatResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "lordId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LordServiceHeartbeatBody"
            }
          }
        ],
        "tags": [
          "lord"
        ]
      }
    },
    "/api/v1/lords/{lordId}/lazy-death": {
      "post": {
        "summary": "Acknowledge lazy death",
        "operationId": "LordService_AcknowledgeLazyDeath",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1AcknowledgeLazyDeathResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "lordId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LordServiceAcknowledgeLazyDeathBody"
            }
          }
        ],
        "tags": [
          "lord"
        ]
      }
    },
    "/api/v1/processes": {
      "get": {
        "summary": "List tenant processes",
        "description": "Глобальный view: процессы тенанта со всех lord'ов. Newest first.",
        "operationId": "SchedulerService_ListProcesses",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListProcessesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "tenantId",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "onlyRunning",
            "description": "фильтр: только RUNNING/PAUSED",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "tenant"
        ]
      },
      "post": {
        "summary": "Spawn a new process",
        "description": "Создать процесс в SSI. Placement решает scheduler.",
        "operationId": "SchedulerService_Spawn",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ProcessInfo"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1SpawnRequest"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/processes/{processId}": {
      "get": {
        "summary": "Get process state",
        "description": "Снимок состояния. Idempotent.",
        "operationId": "SchedulerService_GetProcess",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ProcessInfo"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "processId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/processes/{processId}/files": {
      "post": {
        "summary": "Push file to lord",
        "description": "Локальный копи: scheduler координирует передачу файла от тенанта к lord'у.",
        "operationId": "SchedulerService_PushFile",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1PushFileResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "processId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulerServicePushFileBody"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/processes/{processId}/kill": {
      "post": {
        "summary": "Send signal to process (default SIGTERM)",
        "description": "POSIX-семантика через scheduler. SIGKILL если force=true.",
        "operationId": "SchedulerService_Kill",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1KillResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "processId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulerServiceKillBody"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/processes/{processId}/migrate": {
      "post": {
        "summary": "Migrate process to another lord",
        "description": "CRIU checkpoint + restore. Активно во время MIGRATING.",
        "operationId": "SchedulerService_Migrate",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1MigrateResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "processId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulerServiceMigrateBody"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    },
    "/api/v1/processes/{processId}/wait": {
      "post": {
        "summary": "Wait for process exit",
        "description": "Блокирует до exit/stop или timeout.",
        "operationId": "SchedulerService_Wait",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ProcessInfo"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "processId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulerServiceWaitBody"
            }
          }
        ],
        "tags": [
          "tenant"
        ]
      }
    }
  },
  "definitions": {
    "IOChunkStream": {
      "type": "string",
      "enum": [
        "STREAM_UNSPECIFIED",
        "STREAM_STDIN",
        "STREAM_STDOUT",
        "STREAM_STDERR"
      ],
      "default": "STREAM_UNSPECIFIED"
    },
    "LordServiceAcknowledgeLazyDeathBody": {
      "type": "object",
      "properties": {
        "gracePeriodSec": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "LordServiceHeartbeatBody": {
      "type": "object",
      "properties": {
        "cpuUsedPct": {
          "type": "integer",
          "format": "int32",
          "description": "Текущая утилизация (не cumulative — snapshot)."
        },
        "memUsedBytes": {
          "type": "string",
          "format": "int64"
        },
        "activeProcesses": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "ProcessEventEventType": {
      "type": "string",
      "enum": [
        "EVENT_TYPE_UNSPECIFIED",
        "EVENT_TYPE_STATE_CHANGED",
        "EVENT_TYPE_SIGNAL_RECEIVED",
        "EVENT_TYPE_CHILD_SPAWNED",
        "EVENT_TYPE_IO_THRESHOLD",
        "EVENT_TYPE_MIGRATION_COMPLETE"
      ],
      "default": "EVENT_TYPE_UNSPECIFIED",
      "title": "- EVENT_TYPE_IO_THRESHOLD: crossed CPU/MEM threshold"
    },
    "SchedulerServiceKillBody": {
      "type": "object",
      "properties": {
        "signalNumber": {
          "type": "integer",
          "format": "int32",
          "title": "default 15 (SIGTERM)"
        },
        "force": {
          "type": "boolean",
          "title": "true → SIGKILL, bypass grace"
        }
      }
    },
    "SchedulerServiceMigrateBody": {
      "type": "object",
      "properties": {
        "targetLordId": {
          "type": "string",
          "description": "Если target_lord_id пустой И auto=true — scheduler выберет лучший."
        },
        "auto": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "title": "human-readable, логируется"
        }
      }
    },
    "SchedulerServicePushFileBody": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "data": {
          "type": "string",
          "format": "byte"
        },
        "mode": {
          "type": "integer",
          "format": "int64",
          "title": "unix permissions"
        }
      }
    },
    "SchedulerServiceWaitBody": {
      "type": "object",
      "properties": {
        "timeoutSec": {
          "type": "integer",
          "format": "int32",
          "title": "0 = ждать бесконечно, max 600"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1AcknowledgeLazyDeathRequest": {
      "type": "object",
      "properties": {
        "lordId": {
          "type": "string"
        },
        "gracePeriodSec": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1AcknowledgeLazyDeathResponse": {
      "type": "object",
      "properties": {
        "ack": {
          "type": "boolean"
        },
        "drainTimeoutSec": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1CheckpointRequest": {
      "type": "object",
      "properties": {
        "processId": {
          "type": "string"
        },
        "checkpointDir": {
          "type": "string",
          "title": "куда lord положит dump"
        },
        "leaveRunning": {
          "type": "boolean",
          "title": "freeze и продолжать, или полностью остановить"
        }
      }
    },
    "v1CheckpointResponse": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "checkpointPath": {
          "type": "string",
          "title": "путь к dump'у на lord'е"
        },
        "sizeBytes": {
          "type": "string",
          "format": "int64"
        },
        "errorMessage": {
          "type": "string",
          "title": "если ok=false"
        },
        "processId": {
          "type": "string",
          "title": "какой процесс был checkpoint'нут"
        }
      }
    },
    "v1FilePullResponse": {
      "type": "object",
      "properties": {
        "data": {
          "type": "string",
          "format": "byte"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "v1FilePushRequest": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "data": {
          "type": "string",
          "format": "byte"
        },
        "mode": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "v1FilePushResponse": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "v1HeartbeatRequest": {
      "type": "object",
      "properties": {
        "lordId": {
          "type": "string"
        },
        "cpuUsedPct": {
          "type": "integer",
          "format": "int32",
          "description": "Текущая утилизация (не cumulative — snapshot)."
        },
        "memUsedBytes": {
          "type": "string",
          "format": "int64"
        },
        "activeProcesses": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1HeartbeatResponse": {
      "type": "object",
      "properties": {
        "ack": {
          "type": "boolean"
        },
        "nextHeartbeatSec": {
          "type": "integer",
          "format": "int32"
        },
        "drain": {
          "type": "boolean",
          "title": "true → начать lazy death"
        },
        "pendingCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Pending commands от scheduler'а (например \"drain this\", \"reload config\")."
        }
      }
    },
    "v1IOChunk": {
      "type": "object",
      "properties": {
        "stream": {
          "$ref": "#/definitions/IOChunkStream"
        },
        "data": {
          "type": "string",
          "format": "byte"
        },
        "offset": {
          "type": "string",
          "format": "int64",
          "title": "byte offset от начала (для ordering и resume)"
        }
      },
      "description": "IO chunk — для stdin/stdout/stderr стримов."
    },
    "v1InvalidateFileCacheResponse": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      }
    },
    "v1KillRemoteResponse": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      }
    },
    "v1KillRequest": {
      "type": "object",
      "properties": {
        "processId": {
          "type": "string"
        },
        "signalNumber": {
          "type": "integer",
          "format": "int32",
          "title": "default 15 (SIGTERM)"
        },
        "force": {
          "type": "boolean",
          "title": "true → SIGKILL, bypass grace"
        }
      }
    },
    "v1KillResponse": {
      "type": "object",
      "properties": {
        "acknowledged": {
          "type": "boolean"
        },
        "currentState": {
          "$ref": "#/definitions/v1ProcessState"
        }
      }
    },
    "v1ListLordsResponse": {
      "type": "object",
      "properties": {
        "lords": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Lord"
          }
        }
      }
    },
    "v1ListProcessesResponse": {
      "type": "object",
      "properties": {
        "processes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1ProcessInfo"
          }
        },
        "nextPageToken": {
          "type": "string"
        }
      }
    },
    "v1Lord": {
      "type": "object",
      "properties": {
        "lordId": {
          "type": "string",
          "title": "ULID"
        },
        "hostname": {
          "type": "string"
        },
        "os": {
          "type": "string",
          "title": "\"linux\""
        },
        "arch": {
          "type": "string",
          "title": "\"amd64\""
        },
        "cpuCoresPhysical": {
          "type": "integer",
          "format": "int32",
          "description": "Реальные физические ресурсы lord'а (то что есть на машине)."
        },
        "memTotalBytesPhysical": {
          "type": "string",
          "format": "int64"
        },
        "advertisedCpuShares": {
          "type": "integer",
          "format": "int32",
          "description": "NUMA-overcommit (Phase 2): scheduler может сказать kernel'у lord'а\nчто ресурсов больше чем физически. Kernel всё равно будет использовать\nтолько local_capacity, но scheduler знает про overcommit и может\nмигрировать процессы когда нужно.\n\nесли 0 = нет overcommit (= cpu_cores_physical * 100)"
        },
        "advertisedMemBytes": {
          "type": "string",
          "format": "int64",
          "title": "если 0 = нет overcommit (= mem_total_bytes_physical)"
        },
        "cpuUsedPct": {
          "type": "integer",
          "format": "int32",
          "description": "Текущая утилизация."
        },
        "memUsedBytes": {
          "type": "string",
          "format": "int64"
        },
        "activeProcesses": {
          "type": "integer",
          "format": "int32"
        },
        "healthy": {
          "type": "boolean",
          "title": "Health"
        },
        "reputation": {
          "type": "number",
          "format": "double",
          "title": "0.0..1.0"
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time"
        },
        "criuAvailable": {
          "type": "boolean",
          "description": "Поддержка CRIU для миграции."
        }
      },
      "description": "Информация о лорде — \"ядре\" в NUMA-аналогии."
    },
    "v1LordEvent": {
      "type": "object",
      "properties": {
        "registerAck": {
          "$ref": "#/definitions/v1RegisterResponse",
          "title": "ack на Register"
        },
        "heartbeatAck": {
          "$ref": "#/definitions/v1HeartbeatResponse"
        },
        "spawn": {
          "$ref": "#/definitions/v1SpawnRequest",
          "title": "запустить процесс"
        },
        "kill": {
          "$ref": "#/definitions/v1KillRequest",
          "title": "послать сигнал"
        },
        "checkpoint": {
          "$ref": "#/definitions/v1CheckpointRequest",
          "title": "CRIU dump (Phase 3+)"
        },
        "restore": {
          "$ref": "#/definitions/v1RestoreRequest",
          "title": "CRIU restore (Phase 3+)"
        },
        "filePush": {
          "$ref": "#/definitions/v1FilePushRequest",
          "title": "file transfer (Phase 4+)"
        },
        "lazyDeathAck": {
          "$ref": "#/definitions/v1AcknowledgeLazyDeathResponse"
        }
      },
      "description": "LordEvent — то что scheduler шлёт lord'у в Connect stream."
    },
    "v1MigrateResponse": {
      "type": "object",
      "properties": {
        "acknowledged": {
          "type": "boolean"
        },
        "currentState": {
          "$ref": "#/definitions/v1ProcessState",
          "title": "будет MIGRATING потом RUNNING на новом lord'е"
        },
        "newLordId": {
          "type": "string"
        },
        "newLocalPid": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1ProcessEvent": {
      "type": "object",
      "properties": {
        "ref": {
          "$ref": "#/definitions/v1ProcessRef"
        },
        "type": {
          "$ref": "#/definitions/ProcessEventEventType"
        },
        "at": {
          "type": "string",
