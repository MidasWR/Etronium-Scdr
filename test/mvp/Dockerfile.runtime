# Runtime image for Etronium MVP.
# Used by frontend, lord, and tenant containers.
FROM ubuntu:22.04
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash coreutils ca-certificates iproute2 iptables wget \
      libcap2 \
      && rm -rf /var/lib/apt/lists/*

# Binaries built on the host.
COPY bin/scheduler            /usr/local/bin/scheduler
COPY bin/lord                 /usr/local/bin/lord
COPY bin/etronium             /usr/local/bin/etronium
COPY bin/example-stateful     /usr/local/bin/example-stateful

# Phase BPF — schedulerd daemon + sched_ext_final.o BPF object.
# schedulerd loads the BPF object into host kernel via bpftool struct_ops register.
COPY bin/schedulerd          /usr/local/bin/schedulerd
COPY bin/bpf/sched_ext_final.o   /opt/etronium/bpf/sched_ext_final.o
COPY bin/etr_maps.o            /opt/etronium/bpf/etr_maps.o

# We need bpftool + libbpf inside the image (for schedulerd daemon).
# bpftool is provided by linux-tools-common + linux-tools-$(uname -r) on host.
# In container, we just install linux-generic equivalents at build time.
RUN apt-get update && apt-get install -y --no-install-recommends \
      bpftrace linux-tools-generic kmod \
      && rm -rf /var/lib/apt/lists/*

# Tenant alias — в новом дизайне клиент — `tenant`, а не `etronium`.
RUN ln -sf /usr/local/bin/etronium /usr/local/bin/tenant

WORKDIR /root
CMD ["bash"]
