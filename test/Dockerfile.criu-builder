FROM ubuntu:22.04
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash coreutils ca-certificates \
    gcc make pkg-config \
    libprotobuf-c-dev libprotobuf-dev protobuf-c-compiler protobuf-compiler \
    libnl-3-dev libnet-dev libcap-dev libaio-dev uuid-dev python3-protobuf python3-yaml \
    git curl g++ \
    && rm -rf /var/lib/apt/lists/*

ARG CRIU_VERSION=4.2
RUN cd /tmp \
    && curl -fsSL -o criu.tar.gz https://api.github.com/repos/checkpoint-restore/criu/tarball/v${CRIU_VERSION} \
    && tar -xzf criu.tar.gz \
    && cd checkpoint-restore-criu-* \
    && make -j$(nproc) CUDA=no PYCRIU=no \
    && cp criu/criu /usr/local/bin/criu \
    && cd /tmp && rm -rf criu.tar.gz checkpoint-restore-criu-* \
    && criu --version
